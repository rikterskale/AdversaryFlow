# OpenAI-compatible model endpoint
ADVERSARYFLOW_LLM_BASE_URL=https://your-provider.example/v1
ADVERSARYFLOW_LLM_API_KEY=
ADVERSARYFLOW_LLM_MODEL=

# Live grounding
ADVERSARYFLOW_SEARCH_PROVIDER=brave
ADVERSARYFLOW_BRAVE_API_KEY=
ADVERSARYFLOW_ALLOWED_DOMAINS=

# Runtime policy
ADVERSARYFLOW_REQUEST_TIMEOUT=45
ADVERSARYFLOW_SEARCH_TIMEOUT=15
ADVERSARYFLOW_URL_TIMEOUT=10
ADVERSARYFLOW_MAX_SOURCE_BYTES=2000000
ADVERSARYFLOW_NODE_MAX_ATTEMPTS=3
ADVERSARYFLOW_RETRY_BASE_DELAY=0.25
ADVERSARYFLOW_FACTUALITY_THRESHOLD=1.0
ADVERSARYFLOW_FAIL_ON_FACTUALITY=true
ADVERSARYFLOW_REQUIRE_GROUNDING=true

# Durable runs and cache
ADVERSARYFLOW_STORE_DIR=.adversaryflow
ADVERSARYFLOW_SOURCE_CACHE_TTL=86400
